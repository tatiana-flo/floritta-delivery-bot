# --- Required ---
# Telegram bot token from @BotFather → /mybots → choose bot → API Token
TELEGRAM_BOT_TOKEN_DELIVERY_ETA=

# Google Routes API key — enable Routes API in Google Cloud Console
GOOGLE_API_KEY_DELIVERY_ETA=

# Telegram group chat ID (supergroup has -100 prefix)
CHAT_ID_DELIVERY_ETA=-1003698121587

# Shop origin/destination address
SHOP_ADDRESS_DELIVERY_ETA=Unit 3 The Willows, 80 Willow Walk, London SE1 5SY, UK


# --- Optional ---
# Manager whitelist — only these users can save/cancel/reprioritize lists.
# Empty → anyone in the chat can.
# Comma-separated, without @ for usernames; numeric Telegram user IDs.
MANAGER_USERNAMES_DELIVERY_ETA=
MANAGER_IDS_DELIVERY_ETA=

# Parking + walk-to-door minutes per stop
PARKING_MIN_DELIVERY_ETA=7

# SQLite file path. On Railway mount a volume at /data and set this to /data/bot.db.
DATABASE_PATH_DELIVERY_ETA=./bot.db

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
